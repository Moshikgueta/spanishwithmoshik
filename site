</x-dc>
<script type="text/x-dc" data-dc-script data-props="{
  &quot;autoAdvance&quot;: {&quot;editor&quot;: &quot;boolean&quot;, &quot;default&quot;: false, &quot;tsType&quot;: &quot;boolean&quot;, &quot;section&quot;: &quot;התנהגות התרגול&quot;},
  &quot;hintsEnabled&quot;: {&quot;editor&quot;: &quot;boolean&quot;, &quot;default&quot;: true, &quot;tsType&quot;: &quot;boolean&quot;, &quot;section&quot;: &quot;התנהגות התרגול&quot;}
}">
class Component extends DCLogic {
  state = { phase:'loading', screen:'intro', idx:0, data:null, prog:null, sel:null, refOpen:false, saveState:'idle', reviewMode:false };
  KEY = 'swm-workbook-ch03-v1';

  componentDidMount(){
    this.load();
    this._esc = (e)=>{ if(e.key==='Escape' && this.state.refOpen) this.setState({refOpen:false}); };
    window.addEventListener('keydown', this._esc);
  }
  componentWillUnmount(){
    window.removeEventListener('keydown', this._esc);
    clearTimeout(this._saveT); clearTimeout(this._saveT2); clearTimeout(this._adv);
  }

  load = () => {
    this.setState({phase:'loading'});
    fetch('./chapter-03-data.json')
      .then(r=>{ if(!r.ok) throw new Error('load failed'); return r.json(); })
      .then(data=>{
        const prog = this.loadProgress();
        this.setState({phase:'ready', data, prog, idx: Math.min(prog.currentIndex||0, data.exercises.length-1)});
      })
      .catch(()=> this.setState({phase:'error'}));
  };

  defaultProg(){ return {v:1, started:false, chapterCompleted:false, currentIndex:0, lastActivity:Date.now(), ex:{}}; }
  loadProgress(){
    try{
      const raw = localStorage.getItem(this.KEY);
      if(!raw) return this.defaultProg();
      const p = JSON.parse(raw);
      if(!p || p.v!==1 || typeof p.ex!=='object' || !p.ex) return this.defaultProg();
      return Object.assign(this.defaultProg(), p);
    }catch(e){ return this.defaultProg(); }
  }
  persist(){
    const prog = this.state.prog; if(!prog) return;
    prog.lastActivity = Date.now();
    if(this.state.saveState!=='saving') this.setState({saveState:'saving'});
    clearTimeout(this._saveT);
    this._saveT = setTimeout(()=>{
      try{
        localStorage.setItem(this.KEY, JSON.stringify(this.state.prog));
        this.setState({saveState:'saved'});
        clearTimeout(this._saveT2);
        this._saveT2 = setTimeout(()=> this.setState({saveState:'idle'}), 2400);
      }catch(e){ this.setState({saveState:'error'}); }
    }, 380);
  }
  touch(){ this.forceUpdate(); this.persist(); }

  shuffle(arr){ const a=arr.slice(); for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); const t=a[i]; a[i]=a[j]; a[j]=t; } return a; }
  norm(s){ return String(s||'').trim().replace(/\s+/g,' ').toLocaleLowerCase('es'); }

  curEx(){ const {data, idx} = this.state; return data ? data.exercises[idx] : null; }
  isSeqType(ex){ return ex.type==='multiple-choice-sequence' || ex.type==='scenario-choice'; }
  getP(ex){
    const prog = this.state.prog;
    if(!prog.ex[ex.id]) prog.ex[ex.id] = { submitted:false, solved:false, revealed:false, everWrong:false, usedHint:false, attempts:0, hintLevel:0, reviewedOk:false, status:'idle', msg:'', answer:this.blankAnswer(ex) };
    const p = prog.ex[ex.id];
    if(!p.answer) p.answer = this.blankAnswer(ex);
    return p;
  }
  blankAnswer(ex){
    const c = ex.content || {};
    if(ex.type==='matching') return { order:this.shuffle(c.pairs.map((_,i)=>i)), assign:c.pairs.map(()=>-1), locks:c.pairs.map(()=>false), marks:c.pairs.map(()=>'idle') };
    if(this.isSeqType(ex)) return { i:0, items:c.items.map(()=>({picked:-1,checked:false,correct:false})) };
    if(ex.type==='word-bank') return { fill:c.items.map(()=>''), locks:c.items.map(()=>false), marks:c.items.map(()=>'idle') };
    if(ex.type==='error-correction') return { vals:c.items.map(()=>''), locks:c.items.map(()=>false), marks:c.items.map(()=>'idle'), showEx:c.items.map(()=>false) };
    if(ex.type==='dialogue-completion'){ const f={},m={},l={}; c.lines.forEach(x=>{ if(x.blankId){ f[x.blankId]=''; m[x.blankId]='idle'; l[x.blankId]=false; } }); return { fill:f, marks:m, locks:l }; }
    if(ex.type==='ordering') return { seq:[], marks:[] };
    if(ex.type==='reading-comprehension'){ const a={},m={}; c.questions.forEach(q=>{ a[q.id]= q.type==='multi-select'? [] : ''; m[q.id]='idle'; }); return { ans:a, marks:m }; }
    return {};
  }
  frozen(p){
    if(this.state.reviewMode) return !!p.reviewedOk;
    return !!p.submitted;
  }
  flaggedHistory(p){ return !!p && (p.revealed || p.everWrong || p.usedHint || p.attempts>1); }
  needsReview(p){ return this.flaggedHistory(p) && !p.reviewedOk; }

  // ---- navigation / flow ----
  start = () => {
    const prog = this.state.prog; prog.started = true;
    this.setState({screen:'exercise', idx: Math.min(prog.currentIndex||0, this.state.data.exercises.length-1), sel:null});
    this.persist(); window.scrollTo(0,0);
  };
  goTo(i){ const prog=this.state.prog; prog.currentIndex=i; this.setState({idx:i, sel:null}); this.persist(); window.scrollTo(0,0); }
  prev = () => { if(this.state.idx>0 && !this.state.reviewMode) this.goTo(this.state.idx-1); };
  next = () => {
    if(this.state.reviewMode){ this.setState({reviewMode:false, screen:'review', sel:null}); window.scrollTo(0,0); return; }
    const n = this.state.data.exercises.length;
    if(this.state.idx < n-1) this.goTo(this.state.idx+1); else this.finishChapter();
  };
  finishChapter(){
    const {data, prog} = this.state;
    const all = data.exercises.every(ex=> prog.ex[ex.id] && prog.ex[ex.id].submitted);
    if(all) prog.chapterCompleted = true;
    this.setState({screen:'done', sel:null}); this.persist(); window.scrollTo(0,0);
  }
  gotoUnsubmitted = () => {
    const {data, prog} = this.state;
    const i = data.exercises.findIndex(ex=> !(prog.ex[ex.id] && prog.ex[ex.id].submitted));
    this.setState({screen:'exercise', idx: i<0?0:i, sel:null}); window.scrollTo(0,0);
  };
  exit = () => { this.setState({screen:'intro', reviewMode:false, sel:null}); window.scrollTo(0,0); };
  resetChapter = () => {
    if(!window.confirm('לאפס את כל ההתקדמות בפרק? כל התשובות יימחקו.')) return;
    const prog = this.defaultProg();
    this.setState({prog, idx:0, screen:'intro', reviewMode:false, sel:null});
    try{ localStorage.setItem(this.KEY, JSON.stringify(prog)); }catch(e){}
  };
  openReviewList = () => { this.setState({screen:'review', reviewMode:false, sel:null}); window.scrollTo(0,0); };
  backToDone = () => { this.setState({screen:'done', reviewMode:false, sel:null}); window.scrollTo(0,0); };
  openReview(i){
    const ex = this.state.data.exercises[i]; const p = this.getP(ex);
    if(!p.reviewedOk){
      if(p.revealed){ p.answer = this.blankAnswer(ex); p.status='idle'; p.msg=''; }
      else if(this.isSeqType(ex)){
        p.answer.items.forEach(it=>{ if(!it.correct){ it.picked=-1; it.checked=false; } });
        const f = p.answer.items.findIndex(it=>!it.checked); p.answer.i = f<0?0:f;
      }
    }
    this.setState({reviewMode:true, screen:'exercise', idx:i, sel:null});
    this.persist(); window.scrollTo(0,0);
  }

  // ---- checking ----
  focusFeedback(){ setTimeout(()=>{ const el=document.getElementById('swm-feedback'); if(el) el.focus(); }, 90); }
  afterCheck(){ this.touch(); this.focusFeedback(); }

  check = () => {
    const ex = this.curEx(); const p = this.getP(ex);
    if(this.frozen(p)) return;
    const t = ex.type, c = ex.content, a = p.answer;
    let total=0, answered=0, wrong=0, right=0;
    if(t==='matching'){
      total = c.pairs.length;
      if(!a.assign.every(v=>v>=0)){ p.status='incomplete'; p.msg='השלימו את כל ההתאמות לפני הבדיקה.'; this.afterCheck(); return; }
      c.pairs.forEach((pair,i)=>{ const ok = c.pairs[a.assign[i]].right===pair.right; a.marks[i]= ok?'correct':'wrong'; if(ok){ a.locks[i]=true; right++; } else wrong++; });
      answered = total;
    } else if(t==='word-bank'){
      total = c.items.length;
      c.items.forEach((it,i)=>{
        if(a.locks[i]){ right++; answered++; return; }
        if(!a.fill[i]){ a.marks[i]='idle'; return; }
        answered++;
        const ok = a.fill[i]===it.answer;
        a.marks[i]= ok?'correct':'wrong'; if(ok){ a.locks[i]=true; right++; } else wrong++;
      });
      if(!answered){ p.status='incomplete'; p.msg='בחרו מילים מהמחסן לפני הבדיקה.'; this.afterCheck(); return; }
    } else if(t==='error-correction'){
      total = c.items.length;
      c.items.forEach((it,i)=>{
        if(a.locks[i]){ right++; answered++; return; }
        if(!this.norm(a.vals[i])){ a.marks[i]='idle'; a.showEx[i]=false; return; }
        answered++;
        const ok = this.norm(a.vals[i])===this.norm(it.correct);
        a.marks[i]= ok?'correct':'wrong'; a.showEx[i]=true;
        if(ok){ a.locks[i]=true; right++; } else wrong++;
      });
      if(!answered){ p.status='incomplete'; p.msg='כתבו לפחות מילה אחת לפני הבדיקה.'; this.afterCheck(); return; }
    } else if(t==='dialogue-completion'){
      const ids = Object.keys(c.answers); total = ids.length;
      ids.forEach(id=>{
        if(a.locks[id]){ right++; answered++; return; }
        if(!a.fill[id]){ a.marks[id]='idle'; return; }
        answered++;
        const ok = a.fill[id]===c.answers[id];
        a.marks[id]= ok?'correct':'wrong'; if(ok){ a.locks[id]=true; right++; } else wrong++;
      });
      if(!answered){ p.status='incomplete'; p.msg='שבצו משפטים בשיחה לפני הבדיקה.'; this.afterCheck(); return; }
    } else if(t==='ordering'){
      total = c.cards.length;
      if(a.seq.length < total){ p.status='incomplete'; p.msg='סדרו את כל הכרטיסים לפני הבדיקה.'; this.afterCheck(); return; }
      a.marks = a.seq.map((id,i)=> id===c.correctOrder[i] ? 'correct' : 'wrong');
      wrong = a.marks.filter(m=>m==='wrong').length; right = total-wrong; answered = total;
    } else if(t==='reading-comprehension'){
      total = c.questions.length;
      c.questions.forEach(q=>{
        const v = a.ans[q.id];
        const has = q.type==='multi-select' ? (v && v.length>0) : !!v;
        if(!has){ a.marks[q.id]='idle'; return; }
        answered++;
        let ok;
        if(q.type==='multi-select'){ ok = v.slice().sort().join('||')===q.correct.slice().sort().join('||'); }
        else ok = v===q.correct;
        a.marks[q.id]= ok?'correct':'wrong'; if(ok) right++; else wrong++;
      });
      if(!answered){ p.status='incomplete'; p.msg='ענו על השאלות לפני הבדיקה.'; this.afterCheck(); return; }
    } else return;

    p.msg='';
    if(wrong===0 && answered>=total){
      p.status='correct';
      if(!p.submitted) p.solved = !p.revealed;
      p.submitted = true;
      if(this.state.reviewMode) p.reviewedOk = true;
    } else if(wrong===0){
      p.status='progress';
    } else {
      p.attempts += 1; p.everWrong = true;
      p.hintLevel = Math.min(p.attempts, 2);
      if(this.hintsOn()) p.usedHint = true;
      p.status = right>0 ? 'partial' : 'incorrect';
    }
    this.afterCheck();
  };

  hintsOn(){ return this.props.hintsEnabled ?? true; }

  reveal = () => {
    const ex = this.curEx(); const p = this.getP(ex); const c = ex.content; const a = p.answer;
    p.revealed = true; p.solved = false; p.submitted = true; p.status='revealed'; p.msg='';
    if(this.state.reviewMode) p.reviewedOk = false;
    if(ex.type==='matching'){ a.assign = c.pairs.map((_,i)=>i); a.locks = c.pairs.map(()=>true); a.marks = a.marks.map(m=> m==='correct'?'correct':'revealed'); c.pairs.forEach((_,i)=>{ if(a.marks[i]!=='correct') a.marks[i]='revealed'; }); }
    else if(ex.type==='word-bank'){ c.items.forEach((it,i)=>{ if(!a.locks[i]){ a.fill[i]=it.answer; a.marks[i]='revealed'; } a.locks[i]=true; }); }
    else if(ex.type==='error-correction'){ c.items.forEach((it,i)=>{ if(!a.locks[i]){ a.vals[i]=it.correct; a.marks[i]='revealed'; } a.locks[i]=true; a.showEx[i]=true; }); }
    else if(ex.type==='dialogue-completion'){ Object.keys(c.answers).forEach(id=>{ if(!a.locks[id]){ a.fill[id]=c.answers[id]; a.marks[id]='revealed'; } a.locks[id]=true; }); }
    else if(ex.type==='ordering'){ a.seq = c.correctOrder.slice(); a.marks = a.seq.map(()=>'revealed'); }
    else if(ex.type==='reading-comprehension'){ c.questions.forEach(q=>{ if(a.marks[q.id]!=='correct'){ a.ans[q.id] = q.type==='multi-select'? q.correct.slice() : q.correct; a.marks[q.id]='revealed'; } }); }
    this.touch(); this.focusFeedback();
  };

  resetEx = () => {
    const ex = this.curEx(); const p = this.getP(ex);
    p.answer = this.blankAnswer(ex);
    p.status='idle'; p.msg=''; p.hintLevel=0; p.attempts=0; p.revealed=false; p.submitted=false; p.solved=false;
    if(this.state.reviewMode) p.reviewedOk=false;
    this.setState({sel:null}); this.touch();
  };

  // ---- matching ----
  mSelect(i){ const p=this.getP(this.curEx()); if(this.frozen(p)||p.answer.locks[i]) return; this.setState({sel:{k:'mrow',i}}); }
  mSlot(i){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)||a.locks[i]) return;
    if(a.assign[i]>=0){ a.assign[i]=-1; a.marks[i]='idle'; this.setState({sel:{k:'mrow',i}}); this.touch(); }
    else this.setState({sel:{k:'mrow',i}});
  }
  mPick(pi){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)) return;
    if(a.assign.includes(pi)) return;
    const sel=this.state.sel;
    let target = (sel && sel.k==='mrow') ? sel.i : a.assign.findIndex((v,idx)=> v<0 && !a.locks[idx]);
    if(target==null || target<0 || a.locks[target]) return;
    a.assign[target]=pi; a.marks[target]='idle';
    const nxt = a.assign.findIndex((v,idx)=> v<0 && !a.locks[idx]);
    this.setState({sel: nxt>=0 ? {k:'mrow',i:nxt} : null});
    this.touch();
  }

  // ---- sequence ----
  seqPick(oi){
    const p=this.getP(this.curEx()); const a=p.answer; const it=a.items[a.i];
    if(it.checked) return;
    it.picked=oi; this.forceUpdate();
  }
  seqCheck = () => {
    const ex=this.curEx(); const p=this.getP(ex); const a=p.answer; const c=ex.content;
    const it=a.items[a.i];
    if(it.checked || it.picked<0) return;
    it.checked = true;
    it.correct = c.items[a.i].options[it.picked]===c.items[a.i].correct;
    if(!it.correct){ p.attempts+=1; p.everWrong=true; }
    const all = a.items.every(x=>x.checked);
    if(all){
      p.submitted = true;
      const allC = a.items.every(x=>x.correct);
      if(allC && !p.revealed) p.solved = p.solved || !p.everWrong || true;
      p.solved = allC && !p.revealed ? true : p.solved;
      p.status = allC ? 'correct' : 'seqmixed';
      if(this.state.reviewMode && allC) p.reviewedOk = true;
    }
    this.touch();
    if((this.props.autoAdvance ?? false) && it.correct && !all){
      clearTimeout(this._adv); this._adv=setTimeout(this.seqAdvance, 900);
    }
  };
  seqAdvance = () => {
    const p=this.getP(this.curEx()); const a=p.answer;
    let n=-1;
    for(let k=1;k<=a.items.length;k++){ const j=(a.i+k)%a.items.length; if(!a.items[j].checked){ n=j; break; } }
    if(n<0) n=Math.min(a.i+1, a.items.length-1);
    a.i=n; this.touch();
  };
  seqStep(d){
    const p=this.getP(this.curEx()); const a=p.answer;
    a.i=Math.max(0, Math.min(a.items.length-1, a.i+d)); this.forceUpdate();
  }

  // ---- word bank ----
  wbSlot(i){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)||a.locks[i]) return;
    if(a.fill[i]){ a.fill[i]=''; a.marks[i]='idle'; this.setState({sel:{k:'wbrow',i}}); this.touch(); }
    else this.setState({sel:{k:'wbrow',i}});
  }
  wbPick(word){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)) return;
    if(a.fill.includes(word)) return;
    const sel=this.state.sel;
    let target = (sel && sel.k==='wbrow') ? sel.i : a.fill.findIndex((v,idx)=> !v && !a.locks[idx]);
    if(target==null || target<0 || a.locks[target]) return;
    a.fill[target]=word; a.marks[target]='idle';
    const nxt = a.fill.findIndex((v,idx)=> !v && !a.locks[idx]);
    this.setState({sel: nxt>=0 ? {k:'wbrow',i:nxt} : null});
    this.touch();
  }

  // ---- error correction ----
  efChange(i){
    return (e)=>{
      const p=this.getP(this.curEx()); const a=p.answer;
      if(this.frozen(p)||a.locks[i]) return;
      a.vals[i]=e.target.value; a.marks[i]='idle'; a.showEx[i]=false;
      this.touch();
    };
  }

  // ---- dialogue ----
  dlSlot(id){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)||a.locks[id]) return;
    if(a.fill[id]){ a.fill[id]=''; a.marks[id]='idle'; this.setState({sel:{k:'dlslot',id}}); this.touch(); }
    else this.setState({sel:{k:'dlslot',id}});
  }
  dlPick(chunk){
    const ex=this.curEx(); const p=this.getP(ex); const a=p.answer; const c=ex.content;
    if(this.frozen(p)) return;
    if(Object.values(a.fill).includes(chunk)) return;
    const sel=this.state.sel;
    let target=null;
    if(sel && sel.k==='dlslot' && !a.fill[sel.id] && !a.locks[sel.id]) target=sel.id;
    else { const line=c.lines.find(l=> l.blankId && !a.fill[l.blankId] && !a.locks[l.blankId]); target=line?line.blankId:null; }
    if(!target) return;
    a.fill[target]=chunk; a.marks[target]='idle';
    const nline=c.lines.find(l=> l.blankId && !a.fill[l.blankId] && !a.locks[l.blankId]);
    this.setState({sel: nline ? {k:'dlslot',id:nline.blankId} : null});
    this.touch();
  }

  // ---- ordering ----
  odPick(cardId){
    const ex=this.curEx(); const p=this.getP(ex); const a=p.answer;
    if(this.frozen(p)) return;
    if(a.seq.includes(cardId) || a.seq.length>=ex.content.cards.length) return;
    a.seq.push(cardId); a.marks=[]; if(p.status!=='idle'&&p.status!=='incomplete') p.status='idle';
    this.touch();
  }
  odRemove(pos){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)) return;
    a.seq.splice(pos,1); a.marks=[]; if(p.status!=='idle'&&p.status!=='incomplete') p.status='idle';
    this.touch();
  }

  // ---- reading ----
  rdPick(qid, opt, isMulti){
    const p=this.getP(this.curEx()); const a=p.answer;
    if(this.frozen(p)) return;
    if(isMulti){ const arr=a.ans[qid]; const ix=arr.indexOf(opt); if(ix>=0) arr.splice(ix,1); else arr.push(opt); }
    else a.ans[qid]=opt;
    a.marks[qid]='idle';
    this.touch();
  }

  // ---- styles ----
  pill(extra){ return 'min-height:46px;padding:10px 16px;border-radius:999px;border:1.5px solid #d8cfc2;background:#fff;color:#1e3a5c;font-weight:700;font-size:15px;transition:border-color .15s ease,background .15s ease,opacity .15s ease;'+(extra||''); }
  chipStyle(used){ return used ? this.pill('opacity:.35;') : this.pill(); }
  box(st, extra){
    let s='min-height:48px;padding:12px 16px;border-radius:13px;border:1.5px solid #e0d8ca;background:#fffdf8;color:#2a2520;font-weight:600;font-size:15.5px;text-align:inherit;transition:border-color .15s ease,background .15s ease;'+(extra||'');
    if(st==='selected') s+='border-color:#1e3a5c;background:#eef3f8;box-shadow:0 0 0 1px #1e3a5c inset;';
    else if(st==='correct') s+='border-color:#8fc3a7;background:#eaf5ef;color:#2f7657;';
    else if(st==='wrong') s+='border-color:#ddab99;background:#fae9e4;color:#8f3b24;';
    else if(st==='revealed') s+='border-color:#a9c3d8;background:#edf4f8;color:#1e3a5c;';
    else if(st==='missed') s+='border-color:#e0a63c;background:#fff4d9;color:#7b5a18;';
    else if(st==='empty') s+='border-style:dashed;background:#faf6ee;color:#9c9286;';
    return s;
  }
  markView(mark){
    if(mark==='correct') return {t:'✓', s:'color:#2f7657;font-weight:900;font-size:17px;'};
    if(mark==='wrong') return {t:'✕', s:'color:#8f3b24;font-weight:900;font-size:16px;'};
    if(mark==='revealed') return {t:'✎', s:'color:#1e3a5c;font-weight:900;font-size:15px;'};
    return {t:'', s:'width:14px;'};
  }
  navBtn(disabled, primary){
    if(primary) return 'min-height:48px;padding:0 24px;border:0;border-radius:999px;background:#b5502f;color:#fff;font-weight:800;font-size:15px;box-shadow:0 10px 24px rgba(181,80,47,.2);';
    let s='min-height:46px;padding:0 18px;border:1px solid #d8cfc2;border-radius:999px;background:#fff;color:#1e3a5c;font-weight:800;font-size:14px;';
    if(disabled) s+='opacity:.4;';
    return s;
  }

  renderVals(){
    const {phase, screen, idx, data, prog, sel, refOpen, saveState, reviewMode} = this.state;
    const v = {
      refOpen,
      toggleRef: ()=>this.setState({refOpen:!this.state.refOpen}),
      closeRef: ()=>this.setState({refOpen:false}),
      isLoading: phase==='loading',
      isError: phase==='error',
      onRetryLoad: this.load,
      isIntro:false, isExercise:false, isDone:false, isReviewList:false,
      showExit:false, onExit:this.exit, reviewMode,
      saveText:'', saveColor:'#746d63',
      chTitle:'', chSubtitle:'', chDesc:'', chLevel:'', chTime:'', goals:[],
      isMatching:false, isSeq:false, isWordBank:false, isErrorFix:false, isDialogue:false, isOrdering:false, isReading:false,
      fbShow:false, hintShow:false, revealShow:false, primaryShow:false,
      refTitle:'', refIntro:'', refItems:[],
      submittedCount:0, segs:[]
    };
    const saveMap = { idle:['נשמר אוטומטית','#9c9286'], saving:['שומרים את ההתקדמות...','#746d63'], saved:['ההתקדמות נשמרה ✓','#2f7657'], error:['לא הצלחנו לשמור כרגע. התשובות נשמרו במכשיר ואפשר לנסות שוב.','#8f3b24'] };
    v.saveText = saveMap[saveState][0]; v.saveColor = saveMap[saveState][1];
    if(phase!=='ready' || !data) return v;

    const ch = data.chapter, exs = data.exercises;
    v.chTitle=ch.titleHe; v.chSubtitle=ch.subtitleEs; v.chDesc=ch.descriptionHe; v.chLevel=ch.level; v.chTime=ch.estimatedTimeHe;
    v.goals = ch.learningGoalsHe.map(t=>({t}));
    const ref = ch.reference || {};
    v.refTitle = ref.titleHe || 'צריכים תזכורת?';
    v.refIntro = ref.introHe || '';
    v.refItems = (ref.items||[]).map(it=>({ term: it.termHe, examples: it.examples, dir: it.dir||'ltr', lang: it.lang||'es' }));
    const submitted = exs.filter(e=> prog.ex[e.id] && prog.ex[e.id].submitted).length;
    v.submittedCount = submitted;
    v.showExit = screen!=='intro';

    if(screen==='intro'){
      v.isIntro=true;
      v.hasProgress = !!prog.started && Object.keys(prog.ex).length>0;
      v.startLabel = v.hasProgress ? (prog.chapterCompleted ? 'חזרה לפרק' : 'ממשיכים מתרגיל '+((prog.currentIndex||0)+1)) : 'מתחילים לתרגל';
      v.onStart = this.start;
      v.onResetChapter = this.resetChapter;
      return v;
    }

    if(screen==='review'){
      v.isReviewList=true;
      const items = exs.map((e,i)=>({e,i,p:prog.ex[e.id]})).filter(x=> this.flaggedHistory(x.p));
      v.rvEmpty = items.length===0;
      v.rvItems = items.map(({e,i,p})=>{
        let reason = p.revealed ? 'הוצג פתרון' : (p.everWrong ? 'נדרש יותר מניסיון אחד' : 'נעזרתם ברמז');
        const done = !!p.reviewedOk;
        return {
          num:String(i+1).padStart(2,'0'), title:e.titleHe, reason,
          stateLabel: done ? 'הושלם בחזרה ✓' : 'לחזרה',
          stateStyle: done ? 'flex:0 0 auto;padding:7px 12px;border-radius:999px;background:#eaf5ef;color:#2f7657;font-size:11px;font-weight:800;' : 'flex:0 0 auto;padding:7px 12px;border-radius:999px;background:#fff4d9;color:#7b5a18;font-size:11px;font-weight:800;',
          onOpen: ()=>this.openReview(i),
          style:'display:flex;align-items:center;gap:14px;width:100%;padding:14px 16px;border:1px solid '+(done?'#a8cbb8':'#e5ded2')+';border-radius:14px;background:#fffdf8;text-align:right;transition:border-color .15s ease;'
        };
      });
      v.onBackToDone = this.backToDone;
      return v;
    }

    if(screen==='done'){
      v.isDone=true;
      const all = submitted===exs.length;
      v.doneAll = all; v.doneNotAll = !all;
      let ind=0, hint=0, rev=0;
      exs.forEach(e=>{ const p=prog.ex[e.id]; if(!p) return;
        if(p.solved && !p.everWrong && !p.usedHint && !p.revealed) ind++;
        else if(p.solved) hint++;
        if(this.needsReview(p)) rev++;
      });
      v.statIndependent=ind; v.statHinted=hint; v.statReview=rev;
      v.reviewCount=rev;
      v.hasReviewItems = exs.some(e=> this.flaggedHistory(prog.ex[e.id]));
      v.onOpenReviewList = this.openReviewList;
      v.onBackToIntro = this.exit;
      v.onGotoUnsubmitted = this.gotoUnsubmitted;
      return v;
    }

    // exercise screen
    v.isExercise=true;
    const ex = exs[idx]; const p = this.getP(ex); const c = ex.content; const a = p.answer;
    const frozen = this.frozen(p);
    v.exCounter = 'תרגיל '+(idx+1)+' מתוך '+exs.length;
    v.exTypeLabel = ex.typeLabelHe;
    v.exTitle = ex.titleHe;
    v.exInstructions = ex.instructionsHe;
    v.segs = exs.map((e,i)=>{
      const pp = prog.ex[e.id];
      let bg = '#e2d9c8';
      if(i===idx) bg='#1e3a5c';
      else if(pp && pp.submitted) bg = (pp.revealed||pp.everWrong) ? '#e0a63c' : '#2f7657';
      return {style:'flex:1;min-width:8px;height:6px;border-radius:99px;background:'+bg+';transition:background .3s ease;'};
    });

    const isSeq = this.isSeqType(ex);
    if(ex.type==='matching'){
      v.isMatching=true;
      v.mBankLabel = c.bankLabelHe;
      v.mRows = c.pairs.map((pair,i)=>{
        const selected = !frozen && sel && sel.k==='mrow' && sel.i===i && !a.locks[i];
        const mark = a.marks[i];
        const assigned = a.assign[i];
        let leftState = selected?'selected':(mark==='correct'?'correct':(mark==='wrong'?'wrong':(mark==='revealed'?'revealed':'idle')));
        const slotFilled = assigned>=0;
        let slotState = slotFilled ? leftState==='selected'?'selected':leftState : (selected?'selected':'empty');
        if(slotFilled && leftState==='idle') slotState='idle';
        return {
          left: pair.left,
          leftDir: c.leftDir||'auto',
          leftStyle: this.box(leftState,'flex:0 1 auto;min-width:96px;font-weight:700;'),
          onSelect: ()=>this.mSelect(i),
          selected, locked: a.locks[i] || frozen,
          aria: pair.left+' — בחירת פריט להתאמה',
          slotText: slotFilled ? c.pairs[assigned].right : 'הקישו כאן ואז בחרו מהרשימה למטה',
          slotAria: slotFilled ? 'ההתאמה הנוכחית: '+c.pairs[assigned].right+'. הקשה מסירה אותה.' : 'משבצת ריקה להתאמה',
          slotStyle: this.box(slotFilled?slotState:(selected?'selected':'empty'),'flex:1 1 220px;font-size:14.5px;'),
          onSlot: ()=>this.mSlot(i)
        };
      });
      v.mChips = a.order.map(pi=>{
        const used = a.assign.includes(pi);
        return { label: c.pairs[pi].right, used: used||frozen, style: this.chipStyle(used), onPick: ()=>this.mPick(pi) };
      });
    }
    else if(isSeq){
      v.isSeq=true;
      const i = Math.min(a.i, c.items.length-1);
      const item = c.items[i]; const st = a.items[i];
      v.seqCounter = c.itemNounHe+' '+(i+1)+' מתוך '+c.items.length;
      v.seqDots = a.items.map((x,j)=>{
        let bg='#e2d9c8';
        if(x.checked) bg = x.correct ? '#2f7657' : '#b5502f';
        let s='width:9px;height:9px;border-radius:50%;background:'+bg+';';
        if(j===i) s+='box-shadow:0 0 0 2px #fffdf8,0 0 0 3.5px #1e3a5c;';
        return {style:s};
      });
      v.seqPrompt = item.prompt;
      v.seqPromptDir = c.promptLang==='es'?'ltr':'rtl';
      v.seqPromptLang = c.promptLang==='es'?'es':'he';
      v.seqPromptStyle = c.promptLang==='es'
        ? 'margin:0;color:#1e3a5c;font-weight:800;font-size:38px;letter-spacing:.5px;'
        : 'margin:0;color:#1e3a5c;font-weight:700;font-size:21px;line-height:1.5;';
      const correctIdx = item.options.indexOf(item.correct);
      v.seqOptions = item.options.map((opt,oi)=>{
        let state='idle';
        if(st.checked){
          if(oi===correctIdx) state='correct';
          else if(oi===st.picked) state='wrong';
        } else if(oi===st.picked) state='selected';
        return {
          label: opt,
          dir: c.optionsLang==='es'?'ltr':'rtl',
          lang: c.optionsLang==='es'?'es':'he',
          style: this.box(state, 'width:100%;font-size:17px;min-height:54px;text-align:center;'),
          onPick: ()=>this.seqPick(oi),
          disabled: st.checked,
          selected: oi===st.picked
        };
      });
      v.seqShowExplain = st.checked;
      if(st.checked){
        v.seqExplainTitle = st.correct ? 'נכון!' : 'לא בדיוק. התשובה הנכונה: '+item.correct;
        v.seqExplainText = item.explanationHe;
        v.seqExplainStyle = 'margin-top:12px;padding:14px 16px;border-radius:12px;'+(st.correct?'background:#eaf5ef;color:#2f7657;':'background:#fae9e4;color:#8f3b24;');
      }
      v.seqPrevItem = ()=>this.seqStep(-1);
      v.seqNextItem = ()=>this.seqStep(1);
      v.seqPrevDisabled = i===0;
      v.seqNextDisabled = i===c.items.length-1;
      v.seqNavStyle = 'min-height:40px;padding:0 14px;border:1px solid #d8cfc2;border-radius:999px;background:#fff;color:#746d63;font-weight:700;font-size:12.5px;';
    }
    else if(ex.type==='word-bank'){
      v.isWordBank=true;
      v.wbChips = c.bank.map(word=>{
        const used = a.fill.includes(word);
        return { label: word, used: used||frozen, style: this.chipStyle(used)+'font-size:16px;', onPick: ()=>this.wbPick(word) };
      });
      v.wbRows = c.items.map((it,i)=>{
        const selected = !frozen && sel && sel.k==='wbrow' && sel.i===i && !a.locks[i];
        const mark = a.marks[i];
        const filled = !!a.fill[i];
        let state = mark!=='idle' ? mark : (selected?'selected':(filled?'idle':'empty'));
        const mv = this.markView(mark);
        return {
          prompt: it.promptHe,
          slotText: filled ? a.fill[i] : '···',
          aria: it.promptHe+': '+(filled ? 'המילה '+a.fill[i]+'. הקשה מסירה אותה.' : 'משבצת ריקה — בחרו מילה מהמחסן'),
          slotStyle: this.box(state,'flex:1 1 180px;text-align:center;font-size:16.5px;font-weight:700;'),
          onSlot: ()=>this.wbSlot(i),
          locked: a.locks[i]||frozen,
          mark: mv.t, markStyle: mv.s
        };
      });
    }
    else if(ex.type==='error-correction'){
      v.isErrorFix=true;
      v.efRows = c.items.map((it,i)=>{
        const mark = a.marks[i];
        const mv = this.markView(mark);
        let border='#d7cdbf';
        if(mark==='correct') border='#8fc3a7'; else if(mark==='wrong') border='#ddab99'; else if(mark==='revealed') border='#a9c3d8';
        return {
          incorrect: it.incorrect,
          value: a.vals[i],
          onChange: this.efChange(i),
          locked: a.locks[i]||frozen,
          aria: 'תיקון המילה '+it.incorrect,
          inputStyle: 'flex:1 1 160px;min-height:46px;padding:10px 14px;border:1.5px solid '+border+';border-radius:11px;background:#fff;color:#2a2520;font-size:17px;font-weight:600;outline-offset:2px;',
          mark: mv.t, markStyle: mv.s,
          showExplain: !!a.showEx[i],
          explain: it.explanationHe
        };
      });
    }
    else if(ex.type==='dialogue-completion'){
      v.isDialogue=true;
      v.dlLines = c.lines.map((l,li)=>{
        const isBlank = !!l.blankId;
        const badge = l.speaker==='A'
          ? 'flex:0 0 30px;height:30px;display:grid;place-items:center;border-radius:50%;background:#1e3a5c;color:#fff;font-weight:800;font-size:13px;'
          : 'flex:0 0 30px;height:30px;display:grid;place-items:center;border-radius:50%;background:#f0e8da;color:#8f3b24;font-weight:800;font-size:13px;';
        if(!isBlank) return { speaker:l.speaker, badgeStyle:badge, isText:true, isBlank:false, text:l.text };
        const id = l.blankId;
        const filled = !!a.fill[id];
        const selected = !frozen && sel && sel.k==='dlslot' && sel.id===id && !a.locks[id];
        const mark = a.marks[id];
        let state = mark!=='idle' ? mark : (selected?'selected':(filled?'idle':'empty'));
        return {
          speaker:l.speaker, badgeStyle:badge, isText:false, isBlank:true,
          slotText: filled ? a.fill[id] : '···',
          aria: filled ? 'המשפט ששובץ: '+a.fill[id]+'. הקשה מסירה אותו.' : 'מקום חסר בשיחה — בחרו משפט',
          slotStyle: this.box(state,'flex:1;text-align:left;font-size:15.5px;'),
          onSlot: ()=>this.dlSlot(id),
          locked: a.locks[id]||frozen
        };
      });
      v.dlChips = c.chunks.map(chunk=>{
        const used = Object.values(a.fill).includes(chunk);
        return { label: chunk, used: used||frozen, style: this.chipStyle(used)+'font-size:14.5px;', onPick: ()=>this.dlPick(chunk) };
      });
    }
    else if(ex.type==='ordering'){
      v.isOrdering=true;
      v.odNoteShow = !!ex.orderingNoteHe;
      v.odNote = ex.orderingNoteHe||'';
      const cardById = {}; c.cards.forEach(cd=>{ cardById[cd.id]=cd; });
      v.odSlots = c.cards.map((_,i)=>{
        const id = a.seq[i];
        const filled = !!id;
        const mark = a.marks[i]||'idle';
        let state = mark!=='idle' ? mark : 'idle';
        return {
          num: i+1,
          filled, empty: !filled,
          label: filled ? cardById[id].text : '',
          aria: filled ? 'מקום '+(i+1)+': '+cardById[id].text+'. הקשה מסירה את המשפט.' : '',
          cardStyle: this.box(state,'flex:1;text-align:left;font-size:15.5px;'),
          onRemove: ()=>this.odRemove(i),
          locked: frozen
        };
      });
      v.odPool = c.cards.map(cd=>{
        const used = a.seq.includes(cd.id);
        return { label: cd.text, used: used||frozen, style: this.chipStyle(used)+'font-size:14.5px;', onPick: ()=>this.odPick(cd.id) };
      });
    }
    else if(ex.type==='reading-comprehension'){
      v.isReading=true;
      v.rdLines = c.textLines.map(l=>({
        speaker:l.speaker, text:l.text,
        nameStyle: 'color:'+(l.speaker===c.textLines[0].speaker?'#8f3b24':'#1e3a5c')+';'
      }));
      v.rdQs = c.questions.map((q,qi)=>{
        const isMulti = q.type==='multi-select';
        const val = a.ans[q.id];
        const mark = a.marks[q.id];
        return {
          kicker: 'שאלה '+(qi+1)+(isMulti?' · בחרו שתי תשובות':''),
          question: q.questionHe,
          aria: 'שאלה '+(qi+1)+': '+q.questionHe,
          options: q.options.map(opt=>{
            const picked = isMulti ? val.includes(opt) : val===opt;
            const isCorrect = isMulti ? q.correct.includes(opt) : q.correct===opt;
            let state='idle';
            if(mark==='idle'){ if(picked) state='selected'; }
            else if(mark==='revealed'){ if(isCorrect) state='revealed'; }
            else {
              if(picked && isCorrect) state='correct';
              else if(picked && !isCorrect) state='wrong';
              else if(!picked && isCorrect && mark==='wrong') state='missed';
            }
            return {
              label: opt,
              dir: q.optionsLang==='es'?'ltr':'rtl',
              lang: q.optionsLang==='es'?'es':'he',
              style: this.box(state,'width:100%;font-size:15.5px;'),
              onPick: ()=>this.rdPick(q.id, opt, isMulti),
              disabled: frozen,
              selected: picked
            };
          })
        };
      });
    }

    // feedback
    const fb = this.feedbackFor(ex, p);
    if(fb){
      v.fbShow=true;
      const colors = {
        correct:['#eaf5ef','#2f7657'], wrong:['#fae9e4','#8f3b24'],
        partial:['#fff4d9','#7b5a18'], info:['#edf4f8','#1e3a5c']
      }[fb.kind];
      v.fbStyle = 'margin-top:16px;padding:13px 16px;display:flex;align-items:flex-start;gap:10px;border-radius:11px;background:'+colors[0]+';color:'+colors[1]+';outline:none;';
      v.fbIconStyle = 'width:24px;height:24px;flex:0 0 auto;display:grid;place-items:center;border-radius:50%;background:'+colors[1]+';color:#fff;font-weight:900;font-size:13px;';
      v.fbIcon = fb.icon; v.fbText = fb.text;
    }
    if(this.hintsOn() && p.hintLevel>0 && !p.submitted && ex.hintsHe && ex.hintsHe.length){
      v.hintShow=true;
      v.hintText = ex.hintsHe[Math.min(p.hintLevel,ex.hintsHe.length)-1];
      v.revealShow = !isSeq && p.attempts>=3;
      v.onReveal = this.reveal;
    }

    // action bar
    if(isSeq){
      const i = Math.min(a.i, c.items.length-1);
      const st = a.items[i];
      const allDone = a.items.every(x=>x.checked);
      if(!allDone){
        v.primaryShow=true;
        if(st.checked){ v.primaryLabel=c.nextItemLabelHe; v.primaryOnClick=this.seqAdvance; v.primaryDisabled=false; }
        else { v.primaryLabel='בדיקת תשובה'; v.primaryOnClick=this.seqCheck; v.primaryDisabled=st.picked<0; }
      }
    } else if(!frozen){
      v.primaryShow=true; v.primaryLabel='בדיקת תשובה'; v.primaryOnClick=this.check; v.primaryDisabled=false;
    }
    v.primaryStyle = 'min-height:48px;padding:0 26px;border:0;border-radius:999px;background:#1e3a5c;color:#fff;font-weight:800;font-size:16px;box-shadow:0 10px 24px rgba(30,58,92,.16);transition:background .2s ease,opacity .15s ease;'+(v.primaryDisabled?'opacity:.45;':'');
    v.onResetEx = this.resetEx;
    v.onPrev = this.prev;
    v.prevDisabled = idx===0 || reviewMode;
    v.prevStyle = this.navBtn(v.prevDisabled,false);
    v.onNext = this.next;
    v.nextLabel = reviewMode ? 'חזרה לרשימת החזרה' : (idx<exs.length-1 ? 'לתרגיל הבא' : 'לסיום הפרק');
    v.nextStyle = p.submitted ? this.navBtn(false,true) : this.navBtn(false,false);
    return v;
  }

  feedbackFor(ex, p){
    const st = p.status;
    if(!st || st==='idle') return null;
    const mk = (kind,icon,text)=>({kind,icon,text});
    if(st==='correct'){
      let t = ex.feedbackCorrectHe;
      if(this.state.reviewMode && p.reviewedOk) t += ' התרגיל סומן כהושלם בחזרה.';
      return mk('correct','✓',t);
    }
    if(st==='incorrect') return mk('wrong','!', ex.feedbackIncorrectHe);
    if(st==='partial'){
      if(ex.type==='reading-comprehension' && ex.feedbackPartialHe) return mk('partial','◐', ex.feedbackPartialHe);
      return mk('partial','◐', ex.feedbackIncorrectHe);
    }
    if(st==='progress') return mk('info','◐','עד כאן נכון. המשיכו להשלים את שאר הפריטים.');
    if(st==='incomplete') return mk('info','!', p.msg||'השלימו את התרגיל לפני הבדיקה.');
    if(st==='revealed') return mk('info','✎','הפתרון מוצג. עברו עליו בעיון — התרגיל נוסף לרשימת החזרה ואפשר להמשיך הלאה.');
    if(st==='seqmixed'){
      const ok = p.answer.items.filter(x=>x.correct).length;
      return mk('partial','◐','סיימתם את כל הפריטים: '+ok+' מתוך '+p.answer.items.length+' נכונים. התרגיל נוסף לרשימת החזרה — שם תוכלו לנסות שוב את מה שפספסתם.');
    }
    return null;
  }
}
</script>
</body>
</html>

<!DOCTYPE html>
<html>
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<script src="./support.js"></script>
</head>
<body>
<x-dc>
<helmet>
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Assistant:wght@400;500;600;700;800&family=Frank+Ruhl+Libre:wght@500;700;900&display=swap" rel="stylesheet">
<style>
body{margin:0;background:#f7f3eb;font-family:'Assistant',Arial,sans-serif;-webkit-font-smoothing:antialiased}
a{color:#b5502f}a:hover{color:#8f3b24}
button{font:inherit;cursor:pointer}
button:disabled{cursor:default}
input{font:inherit}
:focus-visible{outline:3px solid #1e3a5c;outline-offset:2px}
@keyframes swm-spin{to{transform:rotate(360deg)}}
@media (prefers-reduced-motion:reduce){*,*::before,*::after{transition:none!important;animation-duration:.01ms!important}}
</style>
</helmet>
<div dir="rtl" lang="he" style="min-height:100vh;color:#2a2520;font-size:16px">
  <header style="position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:8px;flex-wrap:wrap;min-height:60px;padding:8px 16px;border-bottom:1px solid #e5ded2;background:rgba(255,253,248,0.96);backdrop-filter:blur(14px)">
    <div style="display:flex;align-items:center;gap:10px;min-width:0">
      <span aria-hidden="true" style="width:36px;height:36px;flex:0 0 auto;display:grid;place-items:center;border-radius:50% 50% 50% 9px;background:#b5502f;color:#fff;font:900 20px/1 'Frank Ruhl Libre',serif;transform:rotate(-5deg)">M</span>
      <span style="display:grid;line-height:1.1;min-width:0"><strong style="color:#1e3a5c;font:700 15px 'Frank Ruhl Libre',serif;white-space:nowrap">Spanish with Moshik</strong><small style="color:#746d63;font-size:10px;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis">ספרדית בלי כאב ראש · חוברת התרגול</small></span>
    </div>
    <div style="flex:1"></div>
    <span role="status" aria-live="polite" style="font-size:12px;font-weight:700;color:{{ saveColor }}">{{ saveText }}</span>
    <button onClick="{{ toggleRef }}" aria-expanded="{{ refOpen }}" style="min-height:38px;padding:6px 14px;border-radius:999px;border:1px solid #dfceb5;background:#fff8e8;color:#8f3b24;font-weight:800;font-size:13px" style-hover="background:#fff2d6">צריכים תזכורת?</button>
    <sc-if value="{{ showExit }}" hint-placeholder-val="{{ false }}">
      <button onClick="{{ onExit }}" style="min-height:38px;padding:6px 14px;border-radius:999px;border:1px solid #d8cfc2;background:#fff;color:#1e3a5c;font-weight:800;font-size:13px" style-hover="border-color:#1e3a5c">יציאה לחוברת</button>
    </sc-if>
  </header>

  <sc-if value="{{ isLoading }}" hint-placeholder-val="{{ true }}">
    <div data-screen-label="Loading" style="min-height:60vh;display:grid;place-items:center;align-content:center;gap:18px;padding:40px 20px">
      <div aria-label="טוענים את הפרק" style="width:44px;height:44px;border:4px solid #e2d8c8;border-top-color:#b5502f;border-radius:50%;animation:swm-spin 1s linear infinite"></div>
      <p style="margin:0;color:#746d63">טוענים את הפרק...</p>
    </div>
  </sc-if>

  <sc-if value="{{ isError }}" hint-placeholder-val="{{ false }}">
    <div data-screen-label="Error" style="min-height:50vh;display:grid;place-items:center;align-content:center;gap:14px;padding:40px 20px;text-align:center">
      <p style="margin:0;color:#8f3b24;font-weight:700;font-size:17px">לא הצלחנו לטעון את התרגיל. נסו שוב.</p>
      <button onClick="{{ onRetryLoad }}" style="min-height:48px;padding:0 26px;border:0;border-radius:999px;background:#1e3a5c;color:#fff;font-weight:800;font-size:15px" style-hover="background:#b5502f">ניסיון נוסף</button>
    </div>
  </sc-if>

  <sc-if value="{{ isIntro }}" hint-placeholder-val="{{ false }}">
    <main data-screen-label="Chapter intro" style="max-width:820px;margin:0 auto;padding:38px 20px 90px">
      <p style="margin:0 0 12px;color:#b5502f;font-size:13px;font-weight:800;letter-spacing:.05em">פרק 4 · רמה {{ chLevel }} · {{ chTime }}</p>
      <h1 style="margin:0;color:#1e3a5c;font:900 clamp(32px,6vw,50px)/1.12 'Frank Ruhl Libre',serif;letter-spacing:-.01em;text-wrap:pretty">{{ chTitle }}</h1>
      <p dir="ltr" lang="es" style="margin:10px 0 0;color:#8f3b24;font-weight:600;font-size:18px;text-align:right">{{ chSubtitle }}</p>
      <p style="margin:18px 0 0;font-size:17px;line-height:1.8;color:#514a42;max-width:640px;text-wrap:pretty">{{ chDesc }}</p>
      <section style="margin-top:26px;padding:22px 26px;border:1px solid #e5ded2;border-radius:16px;background:#fffdf8">
        <h2 style="margin:0 0 12px;color:#1e3a5c;font:700 19px 'Frank Ruhl Libre',serif">מה תדעו בסוף הפרק</h2>
        <ul style="margin:0;padding:0;list-style:none;display:grid;gap:9px">
          <sc-for list="{{ goals }}" as="g" hint-placeholder-count="4">
            <li style="display:flex;gap:10px;align-items:baseline;line-height:1.6"><span aria-hidden="true" style="color:#e0a63c;font-weight:900">✓</span><span dir="auto">{{ g.t }}</span></li>
          </sc-for>
        </ul>
      </section>
      <div style="display:flex;flex-wrap:wrap;gap:12px;align-items:center;margin-top:28px">
        <button onClick="{{ onStart }}" style="min-height:52px;padding:0 30px;border:0;border-radius:999px;background:#1e3a5c;color:#fff;font-weight:800;font-size:17px;box-shadow:0 12px 30px rgba(30,58,92,.18);transition:background .2s ease" style-hover="background:#b5502f">{{ startLabel }} ←</button>
        <sc-if value="{{ hasProgress }}" hint-placeholder-val="{{ false }}">
          <button onClick="{{ onResetChapter }}" style="min-height:44px;padding:0 18px;border:1px solid #d8cfc2;border-radius:999px;background:transparent;color:#746d63;font-weight:700;font-size:13px" style-hover="border-color:#8f3b24;color:#8f3b24">איפוס הפרק</button>
        </sc-if>
      </div>
      <p style="margin:16px 0 0;color:#9c9286;font-size:12px">10 תרגילים · ההתקדמות נשמרת אוטומטית במכשיר הזה</p>
    </main>
  </sc-if>

  <sc-if value="{{ isExercise }}" hint-placeholder-val="{{ false }}">
    <main data-screen-label="Exercise" style="max-width:820px;margin:0 auto;padding:22px 20px 8px">
      <sc-if value="{{ reviewMode }}" hint-placeholder-val="{{ false }}">
        <div style="margin-bottom:14px;padding:10px 16px;border-radius:10px;border:1px solid #dfceb5;background:#fff4d9;color:#7b5a18;font-weight:700;font-size:13px">מצב חזרה — מתרגלים שוב רק את התרגיל הזה. ההתקדמות המקורית נשמרת.</div>
      </sc-if>
      <div style="display:flex;align-items:baseline;justify-content:space-between;gap:12px;flex-wrap:wrap">
        <p style="margin:0;color:#b5502f;font-size:12.5px;font-weight:800;letter-spacing:.04em">{{ exCounter }} · {{ exTypeLabel }}</p>
        <p style="margin:0;color:#746d63;font-size:12px">{{ chTitle }}</p>
      </div>
      <h1 style="margin:6px 0 0;color:#1e3a5c;font:800 clamp(25px,4.5vw,35px)/1.15 'Frank Ruhl Libre',serif">{{ exTitle }}</h1>
      <div role="progressbar" aria-valuemin="0" aria-valuemax="10" aria-valuenow="{{ submittedCount }}" aria-label="תרגילים שהוגשו בפרק" style="display:flex;gap:5px;margin-top:14px">
        <sc-for list="{{ segs }}" as="s" hint-placeholder-count="10"><span style="{{ s.style }}"></span></sc-for>
      </div>
      <p style="margin:14px 0 0;font-size:16px;line-height:1.7;color:#514a42;font-weight:600">{{ exInstructions }}</p>

      <section style="margin-top:20px">

        <sc-if value="{{ isMatching }}" hint-placeholder-val="{{ false }}">
          <div style="display:grid;gap:10px">
            <sc-for list="{{ mRows }}" as="r" hint-placeholder-count="0">
              <div style="display:flex;flex-wrap:wrap;gap:8px;align-items:stretch">
                <button onClick="{{ r.onSelect }}" disabled="{{ r.locked }}" aria-pressed="{{ r.selected }}" aria-label="{{ r.aria }}" dir="{{ r.leftDir }}" style="{{ r.leftStyle }}">{{ r.left }}</button>
                <button onClick="{{ r.onSlot }}" disabled="{{ r.locked }}" aria-label="{{ r.slotAria }}" dir="auto" style="{{ r.slotStyle }}">{{ r.slotText }}</button>
              </div>
            </sc-for>
          </div>

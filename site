        v.seqExplainText = item.explanationHe;
        v.seqExplainStyle = 'margin-top:12px;padding:14px 16px;border-radius:12px;'+(st.correct?'background:#eaf5ef;color:#2f7657;':'background:#fae9e4;color:#8f3b24;');
      }
      v.seqPrevItem = ()=>this.seqStep(-1);
      v.seqNextItem = ()=>this.seqStep(1);
      v.seqPrevDisabled = i===0;
      v.seqNextDisabled = i===c.items.length-1;
      v.seqNavStyle = 'min-height:40px;padding:0 14px;border:1px solid #d8cfc2;border-radius:999px;background:#fff;color:#746d63;font-weight:700;font-size:12.5px;';
    }
    else if(ex.type==='word-bank'){
      v.isWordBank=true;
      v.wbChips = c.bank.map(word=>{
        const used = a.fill.includes(word);

          aria: 'תיקון המילה '+it.incorrect,
          inputStyle: 'flex:1 1 160px;min-height:46px;padding:10px 14px;border:1.5px solid '+border+';border-radius:11px;background:#fff;color:#2a2520;font-size:17px;font-weight:600;outline-offset:2px;',
          mark: mv.t, markStyle: mv.s,
          showExplain: !!a.showEx[i],
          explain: it.explanationHe
        };
      });
    }
    else if(ex.type==='dialogue-completion'){
      v.isDialogue=true;
      v.dlLines = c.lines.map((l,li)=>{
        const isBlank = !!l.blankId;
        const badge = l.speaker==='A'
          ? 'flex:0 0 30px;height:30px;display:grid;place-items:center;border-radius:50%;background:#1e3a5c;color:#fff;font-weight:800;font-size:13px;'

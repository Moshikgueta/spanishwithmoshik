  { number: 5, title: "בית ועיר", spanish: "Casa y ciudad", description: "מקומות, כיוונים והמרחב שלי", image: "/images/units/unit-05.jpg" },
  { number: 6, title: "היום שלי", spanish: "Mi día", description: "שעות, שגרה ופעולות יומיומיות", image: "/images/units/unit-06.jpg" },
  { number: 7, title: "רצונות ויכולות", spanish: "Quiero y puedo", description: "תוכניות, העדפות ובקשות", image: "/images/units/unit-07.jpg" },

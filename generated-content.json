export function unitForChapter(chapter: number) {
  return unitVisuals[Math.min(unitVisuals.length - 1, Math.max(0, Math.ceil(chapter / 3) - 1))];
}

export const chapterImages: Record<number, string> = Object.fromEntries(
  Array.from({ length: 30 }, (_, index) => [index + 1, unitForChapter(index + 1).image]),
);

import raw from "./generated-content.json";

export type ContentBlock =
  | { type: "paragraph"; text: string; level: number }
  | { type: "table"; rows: string[][] };

export type SourceExercise = {
  id: string;
  number: number;
  title: string;
  prompt: string;
  kind: "speaking" | "matching" | "sorting" | "ordering" | "truefalse" | "correction" | "choice" | "blanks" | "writing" | "reading" | "checklist" | "challenge" | "practice";
  answer: string;
};

export type CourseSection = {
  id: string;
  title: string;
  kind: "unit" | "chapter" | "mini" | "story" | "appendix" | "review" | "intro";
  number: number | null;
  blocks: ContentBlock[];
  exercises?: SourceExercise[];
};

export const content = raw as {
  meta: {
    bookSourcePages: number;
    workbookSourcePages: number;
    bookSectionCount: number;
    workbookSectionCount: number;
    exerciseCount: number;
  };
  bookSections: CourseSection[];
  workbookSections: CourseSection[];
};

